{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "forai",
  "scopeName": "source.forai",
  "fileTypes": ["fa"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#triple-string" },
    { "include": "#string" },
    { "include": "#regex-literal" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#declaration-block" },
    { "include": "#type-declaration-block" },
    { "include": "#docs-block" },
    { "include": "#test-block" },
    { "include": "#import" },
    { "include": "#else-if" },
    { "include": "#case-block" },
    { "include": "#if-block" },
    { "include": "#loop-block" },
    { "include": "#sync-block" },
    { "include": "#step-block" },
    { "include": "#branch-block" },
    { "include": "#on-block" },
    { "include": "#interface" },
    { "include": "#body-keyword" },
    { "include": "#control-flow-keywords" },
    { "include": "#loop-keywords" },
    { "include": "#state-keyword" },
    { "include": "#from-keyword" },
    { "include": "#flow-pipeline" },
    { "include": "#testing" },
    { "include": "#open-modifier" },
    { "include": "#builtin-types" },
    { "include": "#constraint-keys" },
    { "include": "#fat-arrow" },
    { "include": "#operators" },
    { "include": "#namespace-call" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.forai"
    },
    "triple-string": {
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "name": "string.quoted.triple.forai",
      "patterns": [
        {
          "begin": "#\\{",
          "end": "\\}",
          "name": "meta.interpolation.forai",
          "contentName": "source.forai.embedded",
          "patterns": [
            { "include": "#namespace-call" },
            { "include": "#number" },
            { "include": "#boolean" }
          ]
        }
      ]
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.forai",
      "patterns": [
        {
          "match": "\\\\[nrt\\\\\"#]",
          "name": "constant.character.escape.forai"
        },
        {
          "begin": "#\\{",
          "end": "\\}",
          "name": "meta.interpolation.forai",
          "contentName": "source.forai.embedded",
          "patterns": [
            { "include": "#namespace-call" },
            { "include": "#number" },
            { "include": "#boolean" }
          ]
        }
      ]
    },
    "regex-literal": {
      "match": "(?<==>\\s)/(?!\\/)[^/]*/",
      "name": "string.regexp.forai"
    },
    "number": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.forai"
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.forai"
    },
    "declaration-block": {
      "begin": "^\\s*(func|flow|sink|source)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "storage.type.forai" },
        "2": { "name": "entity.name.function.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "storage.type.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "type-declaration-block": {
      "begin": "^\\s*(type|data|enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "storage.type.forai" },
        "2": { "name": "entity.name.type.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "storage.type.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "docs-block": {
      "begin": "^\\s*(docs)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "comment.block.documentation.forai" },
        "2": { "name": "comment.block.documentation.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "comment.block.documentation.forai" }
      },
      "name": "comment.block.documentation.forai",
      "patterns": [
        { "include": "#docs-block" }
      ]
    },
    "test-block": {
      "begin": "^\\s*(test)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "storage.type.forai" },
        "2": { "name": "entity.name.function.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "storage.type.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "else-if": {
      "match": "\\b(else)\\s+(if)\\b",
      "captures": {
        "1": { "name": "keyword.control.conditional.forai" },
        "2": { "name": "keyword.control.conditional.forai" }
      }
    },
    "case-block": {
      "begin": "\\b(case)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.conditional.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "keyword.control.conditional.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "if-block": {
      "begin": "\\b(if)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.conditional.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "keyword.control.conditional.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "loop-block": {
      "begin": "\\b(loop)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.loop.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "keyword.control.loop.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "sync-block": {
      "begin": "\\b(sync)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.forai" }
      },
      "end": "\\b(done)\\b",
      "endCaptures": {
        "1": { "name": "keyword.control.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "step-block": {
      "begin": "\\b(step)\\b",
      "beginCaptures": {
        "1": { "name": "support.function.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "support.function.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "branch-block": {
      "begin": "\\b(branch)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.conditional.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "keyword.control.conditional.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "on-block": {
      "begin": "\\b(on)\\b",
      "beginCaptures": {
        "1": { "name": "support.function.forai" }
      },
      "end": "^\\s*(done)\\b",
      "endCaptures": {
        "1": { "name": "support.function.forai" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "interface": {
      "match": "\\b(take|emit|fail|return)\\b",
      "name": "variable.language.forai"
    },
    "body-keyword": {
      "match": "\\b(body)\\b",
      "name": "storage.type.forai"
    },
    "from-keyword": {
      "match": "\\b(from)\\b",
      "name": "keyword.control.forai"
    },
    "control-flow-keywords": {
      "match": "\\b(when|else)\\b",
      "name": "keyword.control.conditional.forai"
    },
    "loop-keywords": {
      "match": "\\b(as|break)\\b",
      "name": "keyword.control.loop.forai"
    },
    "flow-pipeline": {
      "match": "\\b(next|send|nowait|log|to|then)\\b",
      "name": "support.function.forai"
    },
    "state-keyword": {
      "match": "\\b(state)\\b",
      "name": "storage.modifier.forai"
    },
    "testing": {
      "match": "\\b(must|trap|mock)\\b",
      "name": "keyword.other.forai"
    },
    "import": {
      "match": "^\\s*(use)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.import.forai" },
        "2": { "name": "entity.name.module.forai" }
      }
    },
    "open-modifier": {
      "match": "\\b(open)\\b",
      "name": "storage.modifier.forai"
    },
    "builtin-types": {
      "match": "\\b(text|bool|long|real|uuid|time|list|dict|void|db_conn|http_server|http_conn|ws_conn)\\b",
      "name": "support.type.primitive.forai"
    },
    "constraint-keys": {
      "match": ":[a-z_]+\\b",
      "name": "entity.other.attribute-name.forai"
    },
    "fat-arrow": {
      "match": "=>",
      "name": "keyword.operator.arrow.forai"
    },
    "operators": {
      "match": "==|!=|>=|<=|&&|\\|\\||\\*\\*|[+\\-*/%<>=!]",
      "name": "keyword.operator.forai"
    },
    "namespace-call": {
      "match": "\\b([a-z_][a-z0-9_]*)\\.([a-z_][a-z0-9_]*(?:\\.[a-z_][a-z0-9_]*)*)\\b",
      "captures": {
        "0": { "name": "support.function.builtin.forai" }
      }
    }
  }
}
