{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(func|flow|sink|source|docs|test|type|data|enum|case|loop|sync|if|body|init)\\b",
      "end": "^\\s*done\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(body|init|case|when|else|loop|sync|if|step\\s+.*\\s+then|docs|test|type|data|enum|func|flow|sink|source)\\b",
    "decreaseIndentPattern": "^\\s*(done|else|when)\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*"
}
