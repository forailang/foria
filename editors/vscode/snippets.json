{
  "func": {
    "prefix": "func",
    "body": [
      "docs ${1:Name}",
      "  ${2:Description.}",
      "done",
      "",
      "func ${1:Name}",
      "  take ${3:input} as ${4:text}",
      "  emit ${5:output} as ${6:text}",
      "  fail ${7:error} as ${8:text}",
      "body",
      "  $0",
      "done"
    ],
    "description": "func declaration with docs, take/emit/fail, body"
  },
  "flow": {
    "prefix": "flow",
    "body": [
      "docs ${1:Name}",
      "  ${2:Description.}",
      "done",
      "",
      "flow ${1:Name}",
      "  take ${3:input} as ${4:text}",
      "  emit ${5:output} as ${6:text}",
      "  fail ${7:error} as ${8:text}",
      "body",
      "  step ${9:first}",
      "    $0",
      "  done",
      "done"
    ],
    "description": "flow declaration with docs and step"
  },
  "type": {
    "prefix": "type",
    "body": [
      "docs ${1:Name}",
      "  ${2:Description.}",
      "",
      "  docs ${3:field}",
      "    ${4:Field description.}",
      "  done",
      "done",
      "",
      "type ${1:Name}",
      "  ${3:field} ${5:text}",
      "done"
    ],
    "description": "type declaration with docs"
  },
  "test": {
    "prefix": "test",
    "body": [
      "docs ${1:Name}",
      "  Tests ${2:the function.}",
      "done",
      "",
      "test ${1:Name}",
      "  ${3:result} = ${1:Name}(${4:input})",
      "  must ${3:result} == ${5:expected}",
      "done"
    ],
    "description": "test block with docs and must assertion"
  },
  "docs": {
    "prefix": "docs",
    "body": [
      "docs ${1:Name}",
      "  ${2:Description.}",
      "done"
    ],
    "description": "docs block"
  },
  "case": {
    "prefix": "case",
    "body": [
      "case ${1:value}",
      "  when ${2:\"pattern\"}",
      "    $0",
      "  else",
      "    ",
      "done"
    ],
    "description": "case/when/else pattern matching"
  },
  "loop": {
    "prefix": "loop",
    "body": [
      "loop ${1:items} as ${2:item}",
      "  $0",
      "done"
    ],
    "description": "loop over a list"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if ${1:condition}",
      "  $0",
      "done"
    ],
    "description": "if conditional"
  },
  "sync": {
    "prefix": "sync",
    "body": [
      "[${1:a}, ${2:b}] = sync",
      "  ${1:a} = ${3:op1()}",
      "  ${2:b} = ${4:op2()}",
      "done [${1:a}, ${2:b}]"
    ],
    "description": "sync concurrent block"
  },
  "source": {
    "prefix": "source",
    "body": [
      "docs ${1:Name}",
      "  ${2:Description.}",
      "done",
      "",
      "source ${1:Name}",
      "  emit ${3:event} as ${4:text}",
      "  fail ${5:error} as ${6:text}",
      "body",
      "  on :${7:event} from ${8:op()} to ${9:item}",
      "    emit ${9:item}",
      "  done",
      "done"
    ],
    "description": "source declaration with on event handler"
  },
  "branch": {
    "prefix": "branch",
    "body": [
      "branch when ${1:condition}",
      "  $0",
      "done"
    ],
    "description": "branch conditional pipeline"
  },
  "log": {
    "prefix": "log",
    "body": [
      "log ${1:\"message\"}"
    ],
    "description": "log statement in flow body"
  },
  "on": {
    "prefix": "on",
    "body": [
      "on :${1:event} from ${2:source()} to ${3:item}",
      "  $0",
      "done"
    ],
    "description": "on event handler in source body"
  },
  "step": {
    "prefix": "step",
    "body": [
      "step ${1:module}.${2:Func}(${3:arg} to :${4:param}) then",
      "  next :${5:result} to ${6:var}",
      "done"
    ],
    "description": "step with then/next in flow body"
  }
}
