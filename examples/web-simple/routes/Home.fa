docs Home
    Serves the home page.
done

use pages from "./pages"

flow Home
    take conn_id as http_conn
body
    step pages.Layout("Home" to :title, "<p>Welcome to forai!</p><p>Try <a href=\"/about\">/about</a> or <a href=\"/blog\">/blog</a>.</p>" to :content) then
        next :result to html
    done
    step http.respond.html(conn_id to :conn_id, 200 to :status, html to :body) done
done

test Home
    it "works"
        # Flow: HTTP route handler — stub test
        ok = true
        must ok == true
    done
done
