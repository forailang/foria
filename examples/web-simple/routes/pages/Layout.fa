docs Layout
    Wraps page content in the full HTML layout with navigation and CSS.
done

func Layout
    take title as text
    take content as text
    emit result as text
    fail error as text
body
    data = {title: title, content: content}
    html = tmpl.render("""
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="utf-8">
            <title>{{title}}</title>
            <style>
                body {
                    font-family: system-ui, sans-serif;
                    max-width: 600px;
                    margin: 40px auto;
                    padding: 0 20px;
                    color: #333;
                }
                nav {
                    border-bottom: 1px solid #ddd;
                    padding-bottom: 10px;
                    margin-bottom: 24px;
                }
                nav a {
                    margin-right: 16px;
                    text-decoration: none;
                    color: #0066cc;
                }
                nav a:hover { text-decoration: underline; }
                h1 { margin-top: 0; }
            </style>
        </head>
        <body>
            <nav>
                <a href="/">Home</a>
                <a href="/about">About</a>
                <a href="/blog">Blog</a>
            </nav>
            <h1>{{title}}</h1>
            {{{content}}}
        </body>
        </html>
    """, data)
    emit html
done

test Layout
    r = Layout("Test", "hello world")
    must str.contains(r, "Test")
    must str.contains(r, "hello world")
    must str.contains(r, "/blog")
done
