docs BlogListPage
    Renders the blog listing HTML from a list of post dicts.
done

func BlogListPage
    take posts as list
    emit result as text
    fail error as text
body
    html = "<ul>"
    loop posts as post
        slug = obj.get(post, "slug")
        title = obj.get(post, "title")
        html = html + "<li><a href=\"/blog/#{slug}\">#{title}</a></li>"
    done
    html = html + "</ul>"
    emit html
done

test BlogListPage
    p1 = obj("slug", "a", "title", "A")
    p2 = obj("slug", "b", "title", "B")
    posts = pair(p1, p2)
    r = BlogListPage(posts)
    must str.contains(r, "/blog/a")
    must str.contains(r, "/blog/b")
    must str.contains(r, "A")
    must str.contains(r, "B")
done
