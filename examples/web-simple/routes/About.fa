docs About
    Serves the about page.
done

use pages from "./pages"

flow About
    take conn_id as http_conn
body
    step pages.Layout("About" to :title, "<p>A tiny web server written in the <strong>forai</strong> language.</p>" to :content) then
        next :result to html
    done
    step http.respond.html(conn_id to :conn_id, 200 to :status, html to :body) done
done

test About
    # Flow: HTTP route handler — stub test
    ok = true
    must ok == true
done
