docs main
    A multi-page website with home, about, and blog pages.
    Page content is built with ui.* primitives and rendered to HTML via ui.to_html.
    Demonstrates route matching, UI tree rendering, and the Layout wrapper pattern.
    Listens on port 3000.
done

use sources from "./sources"
use routes from "./routes"

flow main
body
    step sources.Requests(3000 to :port) then
        next :req to req
    done

    state conn_id = obj.get(req, "conn_id")
    state path = obj.get(req, "path")

    choose
        branch route.get("/", req)
            step routes.Home(conn_id to :conn_id) done
        done
        branch route.get("/about", req)
            step routes.About(conn_id to :conn_id) done
        done
        branch route.get("/blog", req)
            step routes.BlogList(conn_id to :conn_id) done
        done
        branch route.get("/blog/:slug", req)
            state blog_params = route.params("/blog/:slug", path)
            step routes.BlogPost(conn_id to :conn_id, blog_params to :params) done
        done
        branch route.post("/contact", req)
            step routes.ContactSubmit(req to :req) done
        done
        branch
            step routes.NotFound(conn_id to :conn_id) done
        done
    done
done

test main
    it "works"
        # Flow: runs HTTP server — stub test
        ok = true
        must ok == true
    done
done
