docs Home
    Serves the home page using UI tree rendering.
done

use pages from "./pages"

flow Home
    take conn_id as http_conn
body
    step pages.HomeView() then
        next :result to content
    done
    step pages.Layout("Home" to :title, content to :content) then
        next :result to html
    done
    step http.respond.html(conn_id to :conn_id, 200 to :status, html to :body) done
done

test Home
    it "works"
        # Flow: HTTP route handler — stub test
        ok = true
        must ok == true
    done
done
