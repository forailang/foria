docs NotFound
    Serves the 404 Not Found page.
done

use pages from "./pages"

flow NotFound
    take conn_id as http_conn
body
    step pages.Layout("Not Found" to :title, "<p>The page you requested does not exist.</p><p><a href=\"/\">Go home</a></p>" to :content) then
        next :result to html
    done
    step http.respond.html(conn_id to :conn_id, 404 to :status, html to :body) done
done

test NotFound
    it "works"
        # Flow: HTTP route handler — stub test
        ok = true
        must ok == true
    done
done
