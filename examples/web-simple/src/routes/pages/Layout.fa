docs Layout
    Wraps page content in the full HTML document with navigation and CSS.
    Content is an HTML string produced by ui.to_html from a UI tree.
done

func Layout
    take title as text
    take content as text
    emit result as text
    fail error as text
body
    data = {title: title, content: content}
    html = tmpl.render("""
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="utf-8">
            <meta name="viewport" content="width=device-width, initial-scale=1">
            <title>{{title}} &mdash; forai</title>
            <style>
                * { box-sizing: border-box; margin: 0; padding: 0; }
                body {
                    font-family: system-ui, -apple-system, sans-serif;
                    max-width: 720px;
                    margin: 0 auto;
                    padding: 24px 20px;
                    color: #1a1a1a;
                    line-height: 1.6;
                    background: #fafafa;
                }
                nav {
                    display: flex;
                    gap: 20px;
                    border-bottom: 2px solid #e0e0e0;
                    padding-bottom: 12px;
                    margin-bottom: 32px;
                }
                nav a {
                    text-decoration: none;
                    color: #0055aa;
                    font-weight: 500;
                }
                nav a:hover { text-decoration: underline; }
                h1 {
                    font-size: 28px;
                    margin-bottom: 24px;
                    color: #111;
                }
                .content span { display: block; margin-bottom: 4px; }
                .content div { margin-bottom: 8px; }
                footer {
                    margin-top: 48px;
                    padding-top: 16px;
                    border-top: 1px solid #e0e0e0;
                    color: #888;
                    font-size: 14px;
                }
            </style>
        </head>
        <body>
            <nav>
                <a href="/">Home</a>
                <a href="/about">About</a>
                <a href="/blog">Blog</a>
            </nav>
            <h1>{{title}}</h1>
            <div class="content">{{{content}}}</div>
            <footer>Built with forai &mdash; pipeline-first application language</footer>
        </body>
        </html>
    """, data)
    emit html
done

test Layout
    it "wraps content in html document"
        r = Layout("Test", "<span>hello world</span>")
        must str.contains(r, "Test")
        must str.contains(r, "hello world")
        must str.contains(r, "/blog")
        must str.contains(r, "footer")
    done
done
