docs BlogPostPage
    Builds a single blog post page as a UI tree and returns HTML.
done

type BlogPost
    slug text
    title text :required => true
    summary text
    content text :required => true
done

docs BlogPost
    A blog post for rendering.

    docs slug
        URL-friendly identifier.
    done
    docs title
        Display title.
    done
    docs summary
        Short description.
    done
    docs content
        Post body text.
    done
done

func BlogPostPage
    take post as BlogPost
    emit result as text
    fail error as text
body
    title = obj.get(post, "title")
    content = obj.get(post, "content")
    tree = ui.vstack(16) do
        ui.text(title, 22)
        ui.text(content)
        ui.text("/blog")
    done
    html = ui.to_html(tree)
    emit html
done

test BlogPostPage
    it "renders post title and content"
        post = {title: "Test", content: "Content here"}
        r = BlogPostPage(post)
        must str.contains(r, "Test")
        must str.contains(r, "Content here")
        must str.contains(r, "/blog")
    done
done
