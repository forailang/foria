uses db
uses pages

docs JobList
    Serves the job list page.
done

flow JobList
    take conn as db_conn
    take req as dict
    emit result as bool
    fail error as text
body
    step obj.get(req to :dict, "conn_id" to :key) then
        next :result to conn_id
    done
    step db.ListJobs(conn to :conn) then
        next :result to jobs
    done
    step pages.JobListPage(jobs to :jobs) then
        next :result to content
    done
    step pages.Layout("Jobs" to :title, content to :content) then
        next :result to html
    done
    state hdrs0 = obj.new()
    state hdrs = obj.set(hdrs0, "content-type", "text/html; charset=utf-8")
    step http.server.respond(conn_id to :conn_id, 200 to :status, hdrs to :hdrs, html to :body) then
        next :result to ok
        emit ok to :result
    done
done

test JobList
  # Flow: HTTP route handler — stub test, integration tested separately
  ok = true
  must ok == true
done
