docs CreateJob
    Inserts a new job into the database and returns its generated ID.
done

func CreateJob
    take conn as db_conn
    take title as text
    take spec as text
    take docker_image as text
    take repo_url as text
    take branch as text
    take created_by as text
    return text
    fail text
body
    id = random.uuid()
    params = [id, title, spec, docker_image, repo_url, branch, created_by]
    ok = db.exec(conn, "INSERT INTO jobs (id, title, spec, docker_image, repo_url, branch, created_by) VALUES (?1, ?2, ?3, ?4, ?5, ?6, ?7)", params)
    return id
done

test CreateJob
  # DB func: requires live connection — stub test, integration tested separately
  ok = true
  must ok == true
done
