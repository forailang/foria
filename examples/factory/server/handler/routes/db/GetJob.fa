docs GetJob
    Retrieves a single job by its ID. Fails if not found.
done

func GetJob
    take conn as db_conn
    take id as text
    return dict
    fail text
body
    params = [id]
    rows = db.query(conn, "SELECT id, title, spec, docker_image, repo_url, branch, status, attempt, max_attempts, created_by, created_at, updated_at FROM jobs WHERE id = ?1", params)
    count = list.len(rows)
    if count == 0
        err_msg = "Job not found"
        fail err_msg
    else
        job = list.get(rows, 0)
        return job
    done
done

test GetJob
    # DB func: requires live connection — stub test, integration tested separately
    ok = true
    must ok == true
done
