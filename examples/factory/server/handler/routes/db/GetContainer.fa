docs GetContainer
    Retrieves a single container by its ID with job and image details. Fails if not found.
done

func GetContainer
    take conn as db_conn
    take id as text
    return dict
    fail text
body
    params = [id]
    rows = db.query(conn, "SELECT c.id, c.job_id, c.image_id, c.ecs_task_arn, c.status, c.started_at, c.stopped_at, j.title as job_title, i.name as image_name FROM containers c LEFT JOIN jobs j ON c.job_id = j.id LEFT JOIN container_images i ON c.image_id = i.id WHERE c.id = ?1", params)
    count = list.len(rows)
    if count == 0
        err_msg = "Container not found"
        fail err_msg
    else
        container = list.get(rows, 0)
        return container
    done
done

test GetContainer
  # DB func: requires live connection — stub test, integration tested separately
  ok = true
  must ok == true
done
