docs UpdateJobStatus
    Updates a job's status and updated_at timestamp.
done

func UpdateJobStatus
    take conn as db_conn
    take id as text
    take status as text
    return bool
    fail text
body
    params = [status, id]
    exec_ok = db.exec(conn, "UPDATE jobs SET status = ?1, updated_at = CURRENT_TIMESTAMP WHERE id = ?2", params)
    result = true
    return result
done

