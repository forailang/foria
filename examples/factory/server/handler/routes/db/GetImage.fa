docs GetImage
    Retrieves a single container image by its ID. Fails if not found.
done

func GetImage
    take conn as db_conn
    take id as text
    return dict
    fail text
body
    params = [id]
    rows = db.query(conn, "SELECT id, name, ecr_uri, dockerfile, description, created_at FROM container_images WHERE id = ?1", params)
    count = list.len(rows)
    if count == 0
        err_msg = "Image not found"
        fail err_msg
    else
        image = list.get(rows, 0)
        return image
    done
done

test GetImage
    # DB func: requires live connection — stub test, integration tested separately
    ok = true
    must ok == true
done
