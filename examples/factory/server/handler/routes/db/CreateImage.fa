docs CreateImage
    Inserts a new container image into the database and returns its generated ID.
done

func CreateImage
    take conn as db_conn
    take name as text
    take ecr_uri as text
    take dockerfile as text
    take description as text
    return text
    fail text
body
    id = random.uuid()
    params = [id, name, ecr_uri, dockerfile, description]
    ok = db.exec(conn, "INSERT INTO container_images (id, name, ecr_uri, dockerfile, description) VALUES (?1, ?2, ?3, ?4, ?5)", params)
    return id
done

test CreateImage
  # DB func: requires live connection — stub test, integration tested separately
  ok = true
  must ok == true
done
