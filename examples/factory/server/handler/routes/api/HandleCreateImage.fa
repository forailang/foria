docs HandleCreateImageResult
    The parsed fields from a create image form submission.

    docs name
        The image name.
    done

    docs ecr_uri
        The ECR URI.
    done

    docs dockerfile
        The Dockerfile contents.
    done

    docs description
        The image description.
    done
done

type HandleCreateImageResult
    name text
    ecr_uri text
    dockerfile text
    description text
done

docs HandleCreateImageError
    An error from the create image handler.

    docs message
        Description of what went wrong.
    done
done

type HandleCreateImageError
    message text
done

docs HandleCreateImage
    Parses URL-encoded form data from a POST body and returns
    the extracted image fields.
done

func HandleCreateImage
    take body as text
    return HandleCreateImageResult
    fail HandleCreateImageError
body
    params = url.query_parse(body)
    name = obj.get(params, "name")
    ecr_uri = obj.get(params, "ecr_uri")
    dockerfile = obj.get(params, "dockerfile")
    description = obj.get(params, "description")

    result = {name: name, ecr_uri: ecr_uri, dockerfile: dockerfile, description: description}
    return result
done

test HandleCreateImage
  body = "name=myimage&ecr_uri=123.dkr.ecr.us-east-1.amazonaws.com/repo:tag&dockerfile=FROM+ubuntu&description=test+image"
  r = HandleCreateImage(body)
  must r.result.name == "myimage"
done
