uses db
uses api

docs CreateImage
    Handles POST to create a new image and redirects to the image detail page.
done

flow CreateImage
    take conn as db_conn
    take req as dict
    emit result as bool
    fail error as text
body
    step obj.get(req to :dict, "conn_id" to :key) then
        next :result to conn_id
    done
    step obj.get(req to :dict, "body" to :key) then
        next :result to body
    done
    step api.HandleCreateImage(body to :body) then
        next :result to parsed
    done
    step obj.get(parsed to :dict, "name" to :key) then
        next :result to i_name
    done
    step obj.get(parsed to :dict, "ecr_uri" to :key) then
        next :result to i_uri
    done
    step obj.get(parsed to :dict, "dockerfile" to :key) then
        next :result to i_dockerfile
    done
    step obj.get(parsed to :dict, "description" to :key) then
        next :result to i_desc
    done
    step db.CreateImage(conn to :conn, i_name to :name, i_uri to :ecr_uri, i_dockerfile to :dockerfile, i_desc to :description) then
        next :result to image_id
    done
    state redir_parts0 = list.new()
    state redir_parts1 = list.append(redir_parts0, "/images/")
    state redir_parts = list.append(redir_parts1, image_id)
    step str.join(redir_parts to :list, "" to :sep) then
        next :result to redir_path
    done
    state rr0 = obj.new()
    state rr1 = obj.set(rr0, "content-type", "text/html; charset=utf-8")
    state rr = obj.set(rr1, "location", redir_path)
    step http.server.respond(conn_id to :conn_id, 303 to :status, rr to :hdrs, "" to :body) then
        next :result to ok
        emit ok to :result
    done
done

test CreateImage
    # Flow: HTTP route handler — stub test, integration tested separately
    ok = true
    must ok == true
done
