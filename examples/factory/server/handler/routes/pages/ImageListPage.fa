docs ImageListPage
    Renders the container image listing page.
done

func ImageListPage
    take images as list
    return text
    fail text
body
    count = list.len(images)

    rows_html = ""
    loop images as img
        iid = obj.get(img, "id")
        iname = obj.get(img, "name")
        iuri = obj.get(img, "ecr_uri")
        idesc = obj.get(img, "description")
        icreated = obj.get(img, "created_at")
        short_id = str.slice(iid, 0, 8)

        row_data = {id: iid, short_id: short_id, name: iname, ecr_uri: iuri, description: idesc, created_at: icreated}
        row = tmpl.render("""
        <tr>
        <td><a href="/images/{{id}}">{{short_id}}</a></td>
        <td><a href="/images/{{id}}">{{name}}</a></td>
        <td><code>{{ecr_uri}}</code></td>
        <td>{{description}}</td>
        <td>{{created_at}}</td>
        </tr>
        """, row_data)
        rows_html = rows_html + row
    done

    has_images = count > 0
    page_data = {rows: rows_html, has_images: has_images, count: count}
    html = tmpl.render("""
    <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <h1>Container Images ({{count}})</h1>
    <a href="/images/new" class="btn btn-primary">New Image</a>
    </div>
    <table>
    <thead>
    <tr>
    <th>ID</th>
    <th>Name</th>
    <th>ECR URI</th>
    <th>Description</th>
    <th>Created</th>
    </tr>
    </thead>
    <tbody>
    {{{rows}}}
    {{^has_images}}
    <tr>
    <td colspan="5" style="text-align:center;color:#999;padding:24px">
    No images yet. Create one to get started.
    </td>
    </tr>
    {{/has_images}}
    </tbody>
    </table>
    </div>
    """, page_data)
    return html
done

test ImageListPage
    images = []
    r = ImageListPage(images)
    must str.contains(r.result, "Images")
done
