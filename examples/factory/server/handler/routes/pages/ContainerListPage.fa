docs ContainerListPage
    Renders the container listing page.
done

func ContainerListPage
    take containers as list
    return text
    fail text
body
    count = list.len(containers)

    rows_html = ""
    loop containers as ctr
        cid = obj.get(ctr, "id")
        cstatus = obj.get(ctr, "status")
        cjob = obj.get(ctr, "job_title")
        cimage = obj.get(ctr, "image_name")
        cstarted = obj.get(ctr, "started_at")
        cstopped = obj.get(ctr, "stopped_at")
        short_id = str.slice(cid, 0, 8)
        lower_status = str.lower(cstatus)
        badge_class = "badge-" + lower_status

        row_data = {id: cid, short_id: short_id, status: cstatus, badge_class: badge_class, job_title: cjob, image_name: cimage, started_at: cstarted, stopped_at: cstopped}
        row = tmpl.render("""
        <tr>
        <td><a href="/containers/{{id}}">{{short_id}}</a></td>
        <td>{{job_title}}</td>
        <td>{{image_name}}</td>
        <td><span class="badge {{badge_class}}">{{status}}</span></td>
        <td>{{started_at}}</td>
        <td>{{stopped_at}}</td>
        </tr>
        """, row_data)
        rows_html = rows_html + row
    done

    has_containers = count > 0
    page_data = {rows: rows_html, has_containers: has_containers, count: count}
    html = tmpl.render("""
    <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <h1>Containers ({{count}})</h1>
    </div>
    <table>
    <thead>
    <tr>
    <th>ID</th>
    <th>Job</th>
    <th>Image</th>
    <th>Status</th>
    <th>Started</th>
    <th>Stopped</th>
    </tr>
    </thead>
    <tbody>
    {{{rows}}}
    {{^has_containers}}
    <tr>
    <td colspan="6" style="text-align:center;color:#999;padding:24px">
    No containers yet. Containers are created when jobs run.
    </td>
    </tr>
    {{/has_containers}}
    </tbody>
    </table>
    </div>
    """, page_data)
    return html
done

test ContainerListPage
  containers = []
  r = ContainerListPage(containers)
  must str.contains(r.result, "Containers")
done
