docs JobListPage
    Renders the job listing page with a table of all jobs.
done

func JobListPage
    take jobs as list
    return text
    fail text
body
    count = list.len(jobs)

    rows_html = ""
    loop jobs as job
        jid = obj.get(job, "id")
        jtitle = obj.get(job, "title")
        jstatus = obj.get(job, "status")
        jcreated = obj.get(job, "created_at")

        short_id = str.slice(jid, 0, 8)

        badge_class = "badge-queued"
        case jstatus
            when "Coding"
                badge_class = "badge-coding"
            when "Testing"
                badge_class = "badge-testing"
            when "Complete"
                badge_class = "badge-complete"
            when "Failed"
                badge_class = "badge-failed"
            when "HumanReview"
                badge_class = "badge-review"
            else
                badge_class = "badge-queued"
        done

        row_data = {id: jid, short_id: short_id, title: jtitle, status: jstatus, badge_class: badge_class, created_at: jcreated}
        row = tmpl.render("""
        <tr>
        <td><a href="/jobs/{{id}}">{{short_id}}</a></td>
        <td><a href="/jobs/{{id}}">{{title}}</a></td>
        <td><span class="badge {{badge_class}}">{{status}}</span></td>
        <td>{{created_at}}</td>
        </tr>
        """, row_data)
        rows_html = rows_html + row
    done

    has_jobs = count > 0
    page_data = {rows: rows_html, has_jobs: has_jobs, count: count}
    html = tmpl.render("""
    <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <h1>Jobs ({{count}})</h1>
    <a href="/jobs/new" class="btn btn-primary">New Job</a>
    </div>
    <table>
    <thead>
    <tr>
    <th>ID</th>
    <th>Title</th>
    <th>Status</th>
    <th>Created</th>
    </tr>
    </thead>
    <tbody>
    {{{rows}}}
    {{^has_jobs}}
    <tr>
    <td colspan="4" style="text-align:center;color:#999;padding:24px">
    No jobs yet. Create one to get started.
    </td>
    </tr>
    {{/has_jobs}}
    </tbody>
    </table>
    </div>
    """, page_data)
    return html
done

test JobListPage
  jobs = []
  r = JobListPage(jobs)
  must str.contains(r.result, "Jobs")
done
