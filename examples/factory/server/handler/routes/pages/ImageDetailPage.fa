docs ImageDetailPage
    Renders the container image detail page.
done

func ImageDetailPage
    take image as dict
    return text
    fail text
body
    iid = obj.get(image, "id")
    iname = obj.get(image, "name")
    iuri = obj.get(image, "ecr_uri")
    idockerfile = obj.get(image, "dockerfile")
    idesc = obj.get(image, "description")
    icreated = obj.get(image, "created_at")

    has_dockerfile = str.len(idockerfile) > 0

    data = {id: iid, name: iname, ecr_uri: iuri, dockerfile: idockerfile, description: idesc, created_at: icreated, has_dockerfile: has_dockerfile}

        html = tmpl.render("""
        <div class="card">
        <h1>{{name}}</h1>
        <table class="meta-table">
        <tr><th>ID</th><td>{{id}}</td></tr>
        <tr><th>ECR URI</th><td><code>{{ecr_uri}}</code></td></tr>
        <tr><th>Description</th><td>{{description}}</td></tr>
        <tr><th>Created</th><td>{{created_at}}</td></tr>
        </table>
        </div>
        {{#has_dockerfile}}
        <div class="card">
        <h2 style="margin-bottom:12px">Dockerfile</h2>
        <pre>{{dockerfile}}</pre>
        </div>
        {{/has_dockerfile}}
        <div style="margin-top:16px">
        <a href="/images">&larr; Back to Images</a>
        </div>
        """, data)
        return html
    done

test ImageDetailPage
  image = {id: "abc", name: "python-dev", ecr_uri: "123.dkr.ecr.us-east-1.amazonaws.com/repo:tag", dockerfile: "FROM ubuntu", description: "A test image", created_at: "2024-01-01"}
  r = ImageDetailPage(image)
  must str.contains(r.result, "python-dev")
done
