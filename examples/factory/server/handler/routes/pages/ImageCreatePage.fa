docs ImageCreatePage
    Renders the container image creation form.
done

func ImageCreatePage
    return text
    fail text
body
    html = """
    <div class="card">
    <h1>New Container Image</h1>
    <form method="POST" action="/images">
    <div class="form-group">
    <label>Name</label>
    <input type="text" name="name" required placeholder="e.g. python-dev, node-agent">
    </div>
    <div class="form-group">
    <label>ECR URI</label>
    <input type="text" name="ecr_uri" required placeholder="123456789.dkr.ecr.us-east-1.amazonaws.com/repo:tag">
    </div>
    <div class="form-group">
    <label>Dockerfile</label>
    <textarea name="dockerfile" placeholder="FROM python:3.12-slim\nRUN pip install ..."></textarea>
    </div>
    <div class="form-group">
    <label>Description</label>
    <input type="text" name="description" placeholder="Short description of this image">
    </div>
    <div style="margin-top:24px">
    <button type="submit" class="btn btn-primary">Create Image</button>
    <a href="/images" style="margin-left:8px">Cancel</a>
    </div>
    </form>
    </div>
    """
    return html
done

test ImageCreatePage
  r = ImageCreatePage()
  must str.contains(r.result, "ECR URI")
done
