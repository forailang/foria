docs ContainerDetailPage
    Renders the container detail page.
done

func ContainerDetailPage
    take container as dict
    return text
    fail text
body
    cid = obj.get(container, "id")
    cjob_id = obj.get(container, "job_id")
    cimage_id = obj.get(container, "image_id")
    carn = obj.get(container, "ecs_task_arn")
    cstatus = obj.get(container, "status")
    cstarted = obj.get(container, "started_at")
    cstopped = obj.get(container, "stopped_at")
    cjob_title = obj.get(container, "job_title")
    cimage_name = obj.get(container, "image_name")

    lower_status = str.lower(cstatus)
    badge_class = "badge-" + lower_status

    data = {id: cid, job_id: cjob_id, image_id: cimage_id, ecs_task_arn: carn, status: cstatus, badge_class: badge_class, started_at: cstarted, stopped_at: cstopped, job_title: cjob_title, image_name: cimage_name}

    html = tmpl.render("""
        <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h1>Container {{id}}</h1>
        <span class="badge {{badge_class}}" style="font-size:14px;padding:6px 14px">{{status}}</span>
        </div>
        <table class="meta-table">
        <tr><th>ID</th><td>{{id}}</td></tr>
        <tr><th>Status</th><td>{{status}}</td></tr>
        <tr><th>Job</th><td><a href="/jobs/{{job_id}}">{{job_title}}</a></td></tr>
        <tr><th>Image</th><td><a href="/images/{{image_id}}">{{image_name}}</a></td></tr>
        <tr><th>ECS Task ARN</th><td><code>{{ecs_task_arn}}</code></td></tr>
        <tr><th>Started</th><td>{{started_at}}</td></tr>
        <tr><th>Stopped</th><td>{{stopped_at}}</td></tr>
        </table>
        </div>
        <div style="margin-top:16px">
        <a href="/containers">&larr; Back to Containers</a>
        </div>
    """, data)
    return html
done

test ContainerDetailPage
    container = {id: "abc", job_id: "j1", image_id: "i1", ecs_task_arn: "arn:aws:ecs:123", status: "Running", started_at: "2024-01-01", stopped_at: "", job_title: "My Job", image_name: "python-dev"}
    r = ContainerDetailPage(container)
    must str.contains(r.result, "abc")
done
