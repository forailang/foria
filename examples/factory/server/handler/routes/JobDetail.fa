uses db
uses pages

docs JobDetail
    Serves the job detail page for a specific job.
done

flow JobDetail
    take conn as db_conn
    take req as dict
    emit result as bool
    fail error as text
body
    step obj.get(req to :dict, "conn_id" to :key) then
        next :result to conn_id
    done
    step obj.get(req to :dict, "path" to :key) then
        next :result to path
    done
    step route.match("/jobs/:id" to :pattern, path to :path) then
        next :result to rm
    done
    step obj.get(rm to :dict, "params" to :key) then
        next :result to rp
    done
    step obj.get(rp to :dict, "id" to :key) then
        next :result to job_id
    done
    step db.GetJob(conn to :conn, job_id to :id) then
        next :result to job
    done
    step pages.JobDetailPage(job to :job) then
        next :result to content
    done
    step pages.Layout("Job Detail" to :title, content to :content) then
        next :result to html
    done
    state hdrs0 = obj.new()
    state hdrs = obj.set(hdrs0, "content-type", "text/html; charset=utf-8")
    step http.server.respond(conn_id to :conn_id, 200 to :status, hdrs to :hdrs, html to :body) then
        next :result to ok
        emit ok to :result
    done
done

test JobDetail
  # Flow: HTTP route handler — stub test, integration tested separately
  ok = true
  must ok == true
done
