uses pages

docs NotFound
    Serves the 404 Not Found page.
done

flow NotFound
    take req as dict
    emit result as bool
    fail error as text
body
    step obj.get(req to :dict, "conn_id" to :key) then
        next :result to conn_id
    done
    step pages.Layout("Not Found" to :title, "<div class=\"card\"><h1>404 Not Found</h1><p>The page you requested does not exist.</p></div>" to :content) then
        next :result to html
    done
    state hdrs0 = obj.new()
    state hdrs = obj.set(hdrs0, "content-type", "text/html; charset=utf-8")
    step http.server.respond(conn_id to :conn_id, 404 to :status, hdrs to :hdrs, html to :body) then
        next :result to ok
        emit ok to :result
    done
done

test NotFound
  # Flow: HTTP route handler — stub test, integration tested separately
  ok = true
  must ok == true
done
