docs Route
    Maps an HTTP request to a handler name string.
done

func Route
    take req as dict
    return text
    fail text
body
    method = obj.get(req, "method")
    path = obj.get(req, "path")

    case method
        when "GET"
            case path
                when "/"
                    h = "job_list"
                    return h
                when "/jobs/new"
                    h = "job_create_form"
                    return h
                when "/images"
                    h = "image_list"
                    return h
                when "/images/new"
                    h = "image_create_form"
                    return h
                when "/containers"
                    h = "container_list"
                    return h
                else
                    rm1 = route.match("/jobs/:id", path)
                    m1 = obj.get(rm1, "matched")
                    rm2 = route.match("/images/:id", path)
                    m2 = obj.get(rm2, "matched")
                    rm3 = route.match("/containers/:id", path)
                    m3 = obj.get(rm3, "matched")
                    if m1
                        h = "job_detail"
                        return h
                    else if m2
                        h = "image_detail"
                        return h
                    else if m3
                        h = "container_detail"
                        return h
                    else
                        h = "not_found"
                        return h
                    done
            done
        when "POST"
            case path
                when "/jobs"
                    h = "create_job_post"
                    return h
                when "/images"
                    h = "create_image_post"
                    return h
                else
                    h = "not_found"
                    return h
            done
        else
            h = "not_found"
            return h
    done
done

test Route
  r = Route("GET", "/jobs")
  must r.result != ""
done
