uses jobs
uses sources

docs RunJobLoopResult
    The result of the job runner loop.

    docs status
        Runner exit status.
    done
done

type RunJobLoopResult
    status text
done

docs RunJobLoopError
    An error from the job runner.

    docs message
        Description of what went wrong.
    done
done

type RunJobLoopError
    message text
done

docs RunJobLoop
    Background job runner that polls the database for Queued jobs
    and drives them through the state machine. Opens its own DB
    connection since it runs as a fire-and-forget background task.
done

flow RunJobLoop
    emit result as RunJobLoopResult
    fail error as RunJobLoopError
body
    state conn = db.open("factory.db")
    step sources.QueuedJobs(conn to :conn) then
        next :job to poll
    done
    step obj.get(poll to :dict, "type" to :key) then
        next :result to action
    done
    branch when action == "queued"
        step jobs.ProcessQueuedJob(conn to :conn, poll to :poll) done
    done
    branch when action == "pr_check"
        step jobs.MonitorPRJob(conn to :conn, poll to :poll) done
    done
done

test RunJobLoop
    # Flow/source/func: I/O dependent — stub test, integration tested separately
    ok = true
    must ok == true
done
