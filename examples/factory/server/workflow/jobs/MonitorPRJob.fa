uses github

docs MonitorPRJob
    Monitors a PrCreated job by checking its GitHub PR state
    and transitioning the job accordingly.
done

func MonitorPRJob
    take conn as db_conn
    take poll as dict
    return bool
    fail text
body
    job = obj.get(poll, "job")
    pr_record = obj.get(poll, "pr_record")
    job_id = obj.get(job, "id")
    job_repo = obj.get(job, "repo_url")
    pr_num_raw = obj.get(pr_record, "pr_number")
    pr_num_str = to.text(pr_num_raw)

    chk_result = github.CheckPR(job_repo, pr_num_str)
    pr_state = obj.get(chk_result, "state")
    _ = term.print("[runner] PR ##{pr_num_str} state: #{pr_state}")

    case pr_state
        when "merged"
            mg_params = [job_id]
            _ = db.exec(conn, "UPDATE jobs SET status = 'Complete', updated_at = CURRENT_TIMESTAMP WHERE id = ?1", mg_params)
            _ = term.print("[runner] #{job_id} -> Complete (PR merged)")
        when "closed"
            fb_result = github.GetPRFeedback(job_repo, pr_num_str)
            fb_text = obj.get(fb_result, "feedback")

            cl_params = [job_id]
            _ = db.exec(conn, "UPDATE pull_requests SET status = 'Closed' WHERE job_id = ?1", cl_params)

            fb_msg_id = random.uuid()
            fb_run_id = random.uuid()
            fb_content = "PR ##{pr_num_str} was closed. Review feedback:\n#{fb_text}"
            fbp = [fb_msg_id, fb_run_id, "system", fb_content]
            _ = db.exec(conn, "INSERT INTO agent_messages (id, run_id, role, content) VALUES (?1, ?2, ?3, ?4)", fbp)

            rq_params = [job_id]
            _ = db.exec(conn, "UPDATE jobs SET status = 'Queued', updated_at = CURRENT_TIMESTAMP WHERE id = ?1", rq_params)
            _ = term.print("[runner] #{job_id} -> Queued (PR closed, re-queued with feedback)")
        else
            _ = term.print("[runner] PR ##{pr_num_str} still open, will check again")
    done

    ok = true
    return ok
done

test MonitorPRJob
    # Flow/source/func: I/O dependent — stub test, integration tested separately
    ok = true
    must ok == true
done
