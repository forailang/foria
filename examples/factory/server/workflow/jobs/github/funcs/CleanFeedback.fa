docs CleanFeedback
    Cleans PR feedback text, returning a default message if empty.
done

func CleanFeedback
    take output as text
    return text
    fail text
body
    trimmed = str.trim(output)
    trimmed_len = str.len(trimmed)
    is_empty = trimmed_len == 0
    feedback = is_empty ? "No review comments" : trimmed
    return feedback
done

test CleanFeedback
  r1 = CleanFeedback("  looks good  ")
  must r1.result == "looks good"
  r2 = CleanFeedback("   ")
  must r2.result == "No review comments"
done
