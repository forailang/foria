docs BuildPRBody
    Builds the GitHub PR body markdown from spec and test summary.
done

func BuildPRBody
    take spec as text
    take test_summary as text
    return text
    fail text
body
    pr_body = "## Spec\n#{spec}\n\n## Test Summary\n#{test_summary}"
    return pr_body
done

test BuildPRBody
  r = BuildPRBody("Implement auth", "All tests passed")
  must str.contains(r.result, "Implement auth")
done
