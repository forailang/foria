docs ParsePRUrl
    Extracts the PR number from a GitHub PR URL.
done

func ParsePRUrl
    take pr_url as text
    return text
    fail text
body
    trimmed = str.trim(pr_url)
    parts = str.split(trimmed, "/")
    parts_len = list.len(parts)
    last_idx = parts_len - 1
    pr_number = list.get(parts, last_idx)
    return pr_number
done

test ParsePRUrl
    r = ParsePRUrl("https://github.com/org/repo/pull/42")
    must r.result == "42"
done
