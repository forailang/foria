docs NormalizeState
    Normalizes a GitHub PR state string to lowercase.
done

func NormalizeState
    take raw_state as text
    return text
    fail text
body
    smap = {MERGED: "merged", CLOSED: "closed", OPEN: "open"}
    state = obj.get(smap, raw_state)
    return state
done

test NormalizeState
  r = NormalizeState("MERGED")
  must r.result == "merged"
done
