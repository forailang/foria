uses funcs

docs TesterAgent
    Runs Claude Code in headless mode to test the coder agent's output.
done

func TesterAgent
    take conn as db_conn
    take job_id as text
    take title as text
    take spec as text
    take code_output as text
    return dict
    fail text
body
    run_id = random.uuid()

    ar_params = [run_id, job_id, "Tester", "Running"]
    _ = db.exec(conn, "INSERT INTO agent_runs (id, job_id, agent_type, status) VALUES (?1, ?2, ?3, ?4)", ar_params)

    prompt = funcs.BuildPrompt(title, spec, code_output, job_id)

    um_id = random.uuid()
    um_params = [um_id, run_id, "user", prompt]
    _ = db.exec(conn, "INSERT INTO agent_messages (id, run_id, role, content) VALUES (?1, ?2, ?3, ?4)", um_params)

    _ = term.print("[tester] Running Claude Code for job #{job_id}...")
    cli_args = ["-p", prompt, "--output-format", "text"]
    output = exec.run("claude", cli_args)
    _ = term.print("[tester] Claude Code finished for job #{job_id}")

    am_id = random.uuid()
    am_params = [am_id, run_id, "assistant", output]
    _ = db.exec(conn, "INSERT INTO agent_messages (id, run_id, role, content) VALUES (?1, ?2, ?3, ?4)", am_params)

    verdict = funcs.ExtractVerdict(output)

    tr_id = random.uuid()
    tr_params = [tr_id, run_id, job_id, verdict, title, output]
    _ = db.exec(conn, "INSERT INTO test_reports (id, run_id, job_id, verdict, summary, details) VALUES (?1, ?2, ?3, ?4, ?5, ?6)", tr_params)

    fin_params = [run_id]
    _ = db.exec(conn, "UPDATE agent_runs SET status = 'Complete', finished_at = CURRENT_TIMESTAMP WHERE id = ?1", fin_params)

    result = {run_id: run_id, verdict: verdict, feedback: output}
    return result
done

test TesterAgent
    # Flow/source/func: I/O dependent — stub test, integration tested separately
    ok = true
    must ok == true
done
