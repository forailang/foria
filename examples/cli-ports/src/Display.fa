docs Display
    Formats and prints a colored table of listening ports.
    Each entry is a dict with port, command, and pid fields.
    Uses term.color for colored output and term.print for plain text.
done

sink Display
    take ports as list
body
    count = list.len(ports)
    if count == 0
        term.print("No listening ports found.")
    else
        # Measure column widths (minimum = header text length)
        pw = 6
        pidw = 8
        cmdw = 7
        loop ports as entry
            pl = str.len(obj.get(entry, "port"))
            if pl > pw
                pw = pl
            done
            pidl = str.len(obj.get(entry, "pid"))
            if pidl > pidw
                pidw = pidl
            done
            cmdl = str.len(obj.get(entry, "command"))
            if cmdl > cmdw
                cmdw = cmdl
            done
        done

        total = pw + pidw + cmdw + 10
        rule = str.repeat("-", total)

        term.print("")
        term.color("  Listening Ports", "white")
        term.print("")
        term.print("  #{rule}")

        port_hdr_pad = str.repeat(" ", pw - 4)
        pid_hdr_pad = str.repeat(" ", pidw - 3)
        cmd_hdr_pad = str.repeat(" ", cmdw - 7)
        header = "  PORT#{port_hdr_pad} | PID#{pid_hdr_pad} | COMMAND#{cmd_hdr_pad}"
        term.print(header)
        term.print("  #{rule}")

        loop ports as entry
            port = obj.get(entry, "port")
            pid = obj.get(entry, "pid")
            command = obj.get(entry, "command")

            port_pad = str.repeat(" ", pw - str.len(port))
            pid_pad = str.repeat(" ", pidw - str.len(pid))

            row = "  #{port}#{port_pad} | #{pid}#{pid_pad} | #{command}"
            term.color(row, "cyan")
        done

        term.print("  #{rule}")
        term.print("  #{to.text(count)} port(s) listening")
        term.print("")
    done
done

test Display
    mock term.print => true
    mock term.color => true

    it "formats port table"
        e1 = obj("port", "3000", "command", "node", "pid", "1234")
        e2 = obj("port", "80", "command", "nginx", "pid", "5678")
        entries = pair(e1, e2)
        Display(entries)
        must true
    done

    it "handles empty port list"
        entries = list()
        Display(entries)
        must true
    done
done
