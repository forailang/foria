docs Hello
    Renders HTML to the browser DOM.
    Demonstrates dom.write for browser output and pure ops
    (list, obj, str, math) running in WASM.
done

func Hello
    emit result as text
    fail error as text
body
    log.info("browser demo starting")

    dom.set_title("forai browser demo")

    dom.write("<h1>Browser Demo</h1>")
    dom.write("<p>This HTML was generated by a forai WASM module.</p>")

    # Arithmetic
    a = 21
    b = a * 2
    dom.write("<p>The answer is: <strong>#{to.text(b)}</strong></p>")

    # List operations
    items = [10, 20, 30, 40, 50]
    count = list.len(items)
    third = items[2]
    dom.write("<p>List: #{to.text(count)} items, third = #{to.text(third)}</p>")

    # Object operations
    person = {name: "Alice", age: 30}
    name = obj.get(person, "name")
    age = obj.get(person, "age")
    dom.write("<p>Person: #{name}, age #{to.text(age)}</p>")

    # String operations
    upper = str.upper("hello world")
    trimmed = str.trim("  spaces  ")
    replaced = str.replace("foo bar foo", "foo", "baz")
    dom.write("<p>Str: upper=#{upper}, trim=#{trimmed}, replace=#{replaced}</p>")

    # Math operations
    pi_approx = 355 / 113
    rounded = math.round(pi_approx, 4)
    dom.write("<p>Math: 355/113 = #{to.text(rounded)}</p>")

    # Loop over a list
    colors = ["red", "green", "blue"]
    dom.write("<ul>")
    loop colors as color
        dom.write("<li style=\"color: #{color}\">#{color}</li>")
    done
    dom.write("</ul>")

    dom.write("<p><em>All ops passed!</em></p>")
    log.info("browser demo complete")
    emit "done"
done

test Hello
    it "works"
        r = Hello()
        must r != ""
    done
done
