use { Commands } from "./sources"
use { Classify } from "./router"
use { Welcome, Print, PrintError } from "./display"
use { HelpText, Namespaces, NsDetail, OpDetail } from "./router/data"

docs StartResult
    Result of the documentation browser session.

    docs status
        Exit status message.
    done
done

type StartResult
    status text
done

docs StartError
    An error from the documentation browser.

    docs message
        Error description.
    done
done

type StartError
    message text
done

docs Start
    Pipeline wiring for the documentation browser.
    Connects user input to a classifier, routes by category to
    the appropriate data func, and displays the result.
    Unknown commands are routed to the error display sink.
done

flow Start
    emit result as StartResult
    fail error as StartError
body
    step Welcome() done
    step Commands() then
        next :cmd to cmd
    done
    step Classify(cmd to :cmd) then
        next :result to kind
    done
    choose
    branch kind == "help"
        step HelpText() then
            next :result to output
        done
        step Print(output to :text) done
    done
    branch kind == "ls"
        step Namespaces() then
            next :result to output
        done
        step Print(output to :text) done
    done
    branch kind == "quit"
        step Print("Goodbye!" to :text) done
    done
    branch kind == "ns"
        step NsDetail(cmd to :ns) then
            next :result to output
        done
        step Print(output to :text) done
    done
    branch kind == "op"
        step OpDetail(cmd to :op) then
            next :result to output
        done
        step Print(output to :text) done
    done
    branch kind == "unknown"
        step PrintError(cmd to :cmd) done
    done
done
done

test Start
    it "works"
        ok = true
        must ok == true
    done
done
