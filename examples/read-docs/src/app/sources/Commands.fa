docs Commands
    Prompts the user for commands and emits them as text events.
    Emits quit and exit as regular commands, then stops the source.
done

source Commands
    emit cmd as text
    fail error as text
body
    on :input from term.prompt("docs> ") to raw
        trimmed = str.trim(raw)
        emit trimmed
        case trimmed
            when "quit"
                break
            when "exit"
                break
        done
    done
done

test Commands
    it "works"
        # Source: reads from terminal — stub test, integration tested separately
        ok = true
        must ok == true
    done
done
