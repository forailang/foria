docs PrintError
    Displays an error message for unknown commands.
done

sink PrintError
    take cmd as text
    emit result as bool
    fail error as text
body
    _ = term.print("")
    _ = term.print("Unknown command: '#{cmd}'. Type 'help' for available commands.")
    ok = true
    emit ok
done

test PrintError
    # Sink: outputs error message, verify it succeeds
    r = PrintError("badcmd")
    must r == true
done
