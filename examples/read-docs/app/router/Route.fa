uses data

docs Route
    Dispatches user commands to the appropriate data function.
    Returns formatted text for display.
    Fails on unknown commands with the unrecognized input.
done

func Route
    take cmd as text
    emit result as text
    fail error as text
body
    if str.contains(cmd, ".")
        result = data.OpDetail(cmd)
        emit result
    else
        case cmd
            when "quit"
                result = "Goodbye!"
                emit result
            when "exit"
                result = "Goodbye!"
                emit result
            when "help"
                result = data.HelpText()
                emit result
            when "ls"
                result = data.Namespaces()
                emit result
            else
                result = data.NsDetail(cmd)
                emit result
        done
    done
done

test Route
  r = Route("help")
  must r != ""
done
